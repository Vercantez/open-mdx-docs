{
	"name": "open-mdx-docs",
	"version": "0.1.0",
	"description": "Mintlify-style MDX docs you own. Add to any docs repo, deploy to Cloudflare or Node. Markdown for agents, AI Search for humans.",
	"type": "module",
	"license": "MIT",
	"bin": {
		"open-mdx-docs": "./bin/open-mdx-docs.mjs"
	},
	"files": [
		"bin",
		"app",
		"vite",
		"workers",
		"server",
		"scripts",
		"public",
		"docs",
		"react-router.config.ts",
		"vite.config.ts",
		"tsconfig.json",
		"wrangler.jsonc",
		"components.json",
		"README.md",
		"AGENTS.md"
	],
	"scripts": {
		"dev": "react-router dev",
		"build": "react-router build",
		"preview": "wrangler dev",
		"deploy": "react-router build && node scripts/nest-base-assets.mjs && wrangler deploy -c wrangler.jsonc --keep-vars",
		"start": "node server/node-server.mjs",
		"typecheck": "react-router typegen && tsc",
		"cf-typegen": "wrangler types",
		"prepublishOnly": "node -e \"console.log('Publishing open-mdx-docs', require('./package.json').version)\""
	},
	"engines": {
		"node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Vercantez/open-mdx-docs.git"
	},
	"bugs": {
		"url": "https://github.com/Vercantez/open-mdx-docs/issues"
	},
	"homepage": "https://github.com/Vercantez/open-mdx-docs#readme",
	"keywords": [
		"mdx",
		"docs",
		"mintlify",
		"cloudflare",
		"documentation",
		"react-router",
		"shadcn"
	],
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.39.2",
		"@mdx-js/mdx": "^3.1.1",
		"@react-router/dev": "^7.16.0",
		"@shikijs/rehype": "^3.20.0",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"github-slugger": "^2.0.0",
		"isbot": "^5.1.17",
		"lucide-react": "^0.562.0",
		"mdast-util-to-string": "^4.0.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-router": "^7.16.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"remark-mdx": "^3.1.1",
		"remark-parse": "^11.0.0",
		"remark-stringify": "^11.0.0",
		"shiki": "^3.20.0",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.0.0",
		"vfile": "^6",
		"vfile-matter": "^5.0.1",
		"vite": "8.0.16",
		"vite-tsconfig-paths": "^5.1.4",
		"wrangler": "^4.97.0"
	},
	"devDependencies": {
		"@types/node": "^20.19.27",
		"@types/react": "^19",
		"@types/react-dom": "^19"
	}
}
