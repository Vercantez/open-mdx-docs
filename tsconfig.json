{
	"include": [
		"app/**/*.ts",
		"app/**/*.tsx",
		"app/**/*.d.ts",
		"workers/**/*.ts",
		"vite/**/*.ts",
		".react-router/types/**/*"
	],
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["vite/client"],
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": { "~/*": ["./app/*"] },
		"rootDirs": [".", "./.react-router/types"]
	}
}
